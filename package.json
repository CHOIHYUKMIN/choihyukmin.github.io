{
  "name": "mindage-app",
  "version": "1.0.0",
  "description": "Mental Age Calculator Mobile App",
  "main": "index.html",
  "scripts": {
    "copy-www": "node -e \"const {cpSync,mkdirSync}=require('fs');mkdirSync('www/js',{recursive:true});mkdirSync('www/css',{recursive:true});['index.html','privacy.html','privacy_en.html','privacy_zh.html','terms.html','favicon.png','favicon.svg','manifest.json'].forEach(f=>{try{cpSync(f,'www/'+f);}catch(e){}});cpSync('css','www/css',{recursive:true,force:true});cpSync('js','www/js',{recursive:true,force:true});\"",
    "sync": "npm run copy-www && npx cap sync",
    "open:android": "npx cap open android"
  },
  "keywords": [
    "mental-age",
    "psychology",
    "mobile-app"
  ],
  "author": "CHOIHYUKMIN",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0"
  }
}
